# ===========================================
# Environment Variables for TahaLearn
# ===========================================
# Copy this file to .env.local and fill in the values

# ----- Brevo (Email Marketing) -----
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The ID of your contact list in Brevo (default: 2)
# Find it in: Contacts > Lists > click on list > ID in URL
BREVO_LIST_ID=2

# ----- Facebook Auto-Post -----
# See scripts/FACEBOOK-SETUP.md for how to get these
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_PAGE_TOKEN=your_long_lived_page_access_token_here
FACEBOOK_POST_LANG=fr

# ----- n8n Webhooks -----
# Webhook URL for welcome email automation
N8N_WEBHOOK_URL=https://n8n.tahalearn.com/webhook/inscription-tahalearn
# Shared secret to authenticate requests from this app to n8n
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here

# ----- Anti-spam -----
# Cloudflare Turnstile (OPT-IN) : laisser vide pour désactiver le widget anti-robot.
# Si renseigné, le widget s'affiche sur les formulaires et le serveur vérifie le token.
# Clés : https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Sel pour hacher les IP dans les logs de rejet (anti rainbow-table). Mettre une valeur aléatoire.
ANTISPAM_SALT=change_me_random_secret

# ----- Future integrations -----
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SITE_URL=https://www.tahalearn.com
